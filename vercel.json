    { "source": "/api/signals/(.*)", "destination": "/api/business/signals/$1" },
    { "source": "/api/signals", "destination": "/api/business/signals" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
