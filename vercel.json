    { "source": "/api/favorites", "destination": "/api/business/favorites" },
    { "source": "/api/ingredients/(.*)", "destination": "/api/business/ingredients/$1" },
    { "source": "/api/ingredients", "destination": "/api/business/ingredients" },
    { "source": "/api/meals/(.*)", "destination": "/api/business/meals/$1" },
    { "source": "/api/meals", "destination": "/api/business/meals" },
    { "source": "/api/notes/(.*)", "destination": "/api/business/notes/$1" },
    { "source": "/api/notes", "destination": "/api/business/notes" },
    { "source": "/api/notifications/(.*)", "destination": "/api/business/notifications/$1" },
    { "source": "/api/notifications", "destination": "/api/business/notifications" },
    { "source": "/api/profile/(.*)", "destination": "/api/business/profile/$1" },
